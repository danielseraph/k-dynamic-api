datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Vessel {
  id                  String   @id @default(uuid())
  name                String
  type                String
  lengthOverall       String
  breadth             String
  draft               String
  mainEngines         String
  bhp                 String
  bollardPull         String
  deckSpace           String
  flag                String
  fuelOil             String
  freshWater          String
  deckCargo           String
  safetyCertifications String   // JSON stringified array of strings
  status              String   // 'Available' | 'On Charter' | 'Maintenance'
  image               String
  gallery             String   // JSON stringified array of strings
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TeamMember {
  id               String   @id @default(uuid())
  name             String
  role             String
  category         String   // 'executive' | 'management' | 'supervisory'
  bio              String
  experience       String
  responsibilities String   // JSON stringified array of strings
  image            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Equipment {
  id          String   @id @default(uuid())
  name        String
  type        String   // 'Fenders' | 'Hoses' | 'Anchors' | 'Spill Response' | 'Other'
  specs       String
  quantity    Int      @default(1)
  status      String   // 'Available' | 'Leased' | 'Maintenance'
  image       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String
  company       String
  serviceNeeded String
  message       String
  messageType   String   // 'Contact' | 'Quote'
  status        String   // 'Unread' | 'Read' | 'Replied'
  quoteDetails  String?  // JSON stringified quote details
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
